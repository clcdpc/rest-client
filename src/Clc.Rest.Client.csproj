<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>netstandard2.0</TargetFramework>
		<RootNamespace>Clc.Rest</RootNamespace>
		<Authors>Central Library Consortium, Michael Fields</Authors>
		<Description>simple http client library</Description>
		<PackageTags>clc, rest, http</PackageTags>
		<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
		<Version>3.0.0-alpha.1</Version>
		<SignAssembly>False</SignAssembly>
		<IncludeSymbols>True</IncludeSymbols>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<PackageId>Clc.Rest.Client</PackageId>
		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<PackageReleaseNotes>Breaking alpha: simplify execution to async-only RestRequest/url/method overloads, remove synchronous Execute&lt;T&gt;, remove sync-over-async response construction, remove legacy response formatter path, require content-aware async formatting, copy response headers/content headers, support absolute URLs, chain request-hook return values, and harden RestRequest defaults.</PackageReleaseNotes>
		<PackageProjectUrl>https://github.com/clcdpc/rest-client</PackageProjectUrl>
		<RepositoryUrl>https://github.com/clcdpc/rest-client</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" Version="13.*" />
	</ItemGroup>

</Project>
